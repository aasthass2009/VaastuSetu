DATABASE_URL="postgresql://USER:PASSWORD@localhost:5434/vaastusetu"

# Clerk (get from clerk.com → Dashboard → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk route config
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Webhook secret (Dashboard → Webhooks → your endpoint → Signing Secret)
CLERK_WEBHOOK_SECRET=whsec_...

# OpenAI (get from platform.openai.com → API Keys)
OPENAI_API_KEY=sk-...

# Razorpay (get from razorpay.com → Settings → API Keys)
# Use rzp_test_ keys for test mode. Complete KYC and use rzp_live_ keys for production.
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
